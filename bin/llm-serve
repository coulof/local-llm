#!/bin/bash
# llm-serve — OpenAI-compatible server on 127.0.0.1:8080 (one model at a time).
#   llm-serve [qwen|mini]   (default: qwen)
set -euo pipefail

BACKEND="${LLM_BACKEND:-llama}"
MODEL_TYPE="${1:-qwen}"

if [[ "$BACKEND" == "mlx" ]]; then
  case "$MODEL_TYPE" in
    qwen) MLX_MODEL="${QWEN_MLX_MODEL:-mlx-community/Qwen2.5-Coder-32B-Instruct-4bit}" ;;
    mini) MLX_MODEL="${MINI_MLX_MODEL:-mlx-community/Ministral-8B-Instruct-2410-4bit}" ;;
    *) echo "unknown model: $MODEL_TYPE (use qwen|mini)" >&2; exit 1 ;;
  esac
  exec "$(dirname "$0")/serve-mlx" "$MLX_MODEL"
else
  MODEL_DIR="${HOME}/lab/llm/models"
  case "$MODEL_TYPE" in
    qwen) MODEL="${MODEL_DIR}/Qwen_Qwen3.6-27B-Q6_K.gguf";       CTX=32768 ;;
    mini) MODEL="${MODEL_DIR}/Ministral-8B-Instruct-2410-Q5_K_M.gguf"; CTX=16384 ;;
    *) echo "unknown model: $MODEL_TYPE (use qwen|mini)" >&2; exit 1 ;;
  esac
  exec llama-server \
    -m "$MODEL" \
    -ngl 99 \
    -c "$CTX" \
    --host 127.0.0.1 --port 8080 \
    --jinja
fi
