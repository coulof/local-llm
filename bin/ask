#!/bin/bash
# ask — top-level routing wrapper for the pipe-friendly one-shot helper.
# Routes to:
#   - Interactive mini or qwen chat if called in a terminal (not piped).
#   - One-shot ask-llama or ask-mlx completions if piped/redirected.
set -euo pipefail

# Parse arguments to detect the model choice (-m mini|qwen).
model="${ASK_MODEL:-mini}"
while getopts ":m:h" opt; do
  case "$opt" in
    m) model="$OPTARG" ;;
    *) ;;
  esac
done
# Reset getopts index so "$@" can be passed to delegated scripts.
OPTIND=1

if [ -t 0 ]; then
  # Called without a | (standard interactive terminal). Route to interactive chats.
  case "$model" in
    qwen)
      exec "$(dirname "$0")/qwen" "$@"
      ;;
    mini)
      exec "$(dirname "$0")/mini" "$@"
      ;;
    *)
      echo "ask: unknown model '$model' (use mini|qwen)" >&2
      exit 1
      ;;
  esac
else
  # Stdin is piped or redirected. Route to one-shot completion.
  BACKEND="${LLM_BACKEND:-llama}"
  case "$BACKEND" in
    mlx)
      exec "$(dirname "$0")/ask-mlx" "$@"
      ;;
    llama|llama.cpp)
      exec "$(dirname "$0")/ask-llama" "$@"
      ;;
    *)
      echo "ask: unknown backend '$BACKEND'. Supported backends: llama, mlx" >&2
      exit 1
      ;;
  esac
fi
